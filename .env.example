# Formspree Endpoint Configuration Example
# Copy this file to '.env' and fill in your Formspree Form ID/endpoint URL.

# You can get your unique Form ID by registering at https://formspree.io/
# Your endpoint URL will look like: https://formspree.io/f/YOUR_FORM_ID
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID
